{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/secret-scan.mjs",
            "if": "Bash(git push*)",
            "timeout": 30,
            "statusMessage": "秘密情報スキャン中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/asset-version-reminder.mjs",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
