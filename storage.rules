rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // パスポート写真 — ゲスト(非認証)からのアップロードを許可、読み取りはオーナーのみ
    match /passport-photos/{guestId}/{fileName} {
      // 非認証アップロード: 5MB以下の画像ファイルのみ
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      // 読み取り: オーナー(role=owner)のみ
      allow read: if request.auth != null
                  && request.auth.token.role == "owner";
    }

    // チェックリスト写真 — 認証済みスタッフ/オーナーのみ
    // パス: checklist-photos/{propertyId}/{checklistId}/{kind}/{filename}
    match /checklist-photos/{propertyId}/{checklistId}/{kind}/{filename} {
      // 読み取り: 認証済みユーザー全員
      allow read: if request.auth != null;
      // 書き込み: オーナー または 該当物件が assignedPropertyIds に含まれるスタッフ
      // 5MB 以下の画像ファイルのみ許可
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (request.auth.token.role == "owner"
                       || request.auth.token.role == "sub_owner"
                       || propertyId in firestore.get(
                            /databases/(default)/documents/staff/$(request.auth.uid)
                          ).data.assignedPropertyIds);
      // 削除: オーナー/サブオーナー または アップロード者本人
      allow delete: if request.auth != null
                    && (request.auth.token.role == "owner"
                        || request.auth.token.role == "sub_owner"
                        || (resource.metadata != null
                            && resource.metadata.uploadedBy == request.auth.uid));
    }

    // 見本写真 — オーナーのみ書き込み可、読み取りは認証済み全員
    // パス: checklist-samples/{propertyId}/{nodeId}/{filename}
    match /checklist-samples/{propertyId}/{nodeId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*')
                   && (request.auth.token.role == "owner"
                       || request.auth.token.role == "sub_owner");
      allow delete: if request.auth != null
                    && (request.auth.token.role == "owner"
                        || request.auth.token.role == "sub_owner");
    }

    // フォーム画像（旧）
    match /form-images/{allPaths=**} {
      allow read;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // その他 — 認証済みのみ
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
